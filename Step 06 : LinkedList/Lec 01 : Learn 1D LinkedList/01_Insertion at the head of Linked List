/*
 ============================================================================
  TITLE:
  Insert a Node at the Front of a Singly Linked List
 ============================================================================
 
  PROBLEM STATEMENT:
  ------------------
  Given the head of a singly linked list and an integer `x`,
  insert a new node with value `x` at the **front (beginning)** of the linked list
  and return the updated head of the list.
 
 ============================================================================
  PROBLEM RESOURCE:
  -----------------
  • GeeksforGeeks:
    https://www.geeksforgeeks.org/problems/insert-at-the-front-of-linked-list/1
 
 ============================================================================
  INTUITION:
  ----------
  • Inserting at the front of a linked list is simple and efficient.
  • We just need to:
      - Create a new node
      - Point it to the current head
      - Update head to this new node
  • No traversal is required.
 
 ============================================================================
  APPROACH:
  ----------
  1. Create a new node with data = x.
  2. Make the new node point to the current head.
  3. Update head to the new node.
  4. Return the updated head.
 
 ============================================================================
  EXAMPLE:
  --------
  Input:
      Linked List: 10 -> 20 -> 30 -> X
      x = 5
 
  Output:
      5 -> 10 -> 20 -> 30 -> X
 
 ============================================================================
  DRY RUN:
  --------
  Initial:
      head → 10 -> 20 -> 30 -> X
 
  Step 1:
      newNode = 5
 
  Step 2:
      newNode.next = head
      5 -> 10 -> 20 -> 30 -> X
 
  Step 3:
      head = newNode
 
  Final:
      head → 5 -> 10 -> 20 -> 30 -> X
 
 ============================================================================
  KEY POINTS:
  ------------
  ✔ No traversal required
  ✔ Constant time insertion
  ✔ Works even if list is empty
  ✔ Head pointer must be updated
 
 ============================================================================
  TIME COMPLEXITY:
  ----------------
  O(1)
  (Insertion at the front is a constant-time operation)
 
 ============================================================================
  SPACE COMPLEXITY:
  -----------------
  O(1)
  (Only one new node is created)
 
 ============================================================================
  SPECIAL NOTES FOR LOGIC:
  ------------------------
  • `newNode.next = head` is crucial:
      - It links the new node to the existing list
  • Updating `head = newNode` makes the new node the first node
  • If the original list is empty (`head == null`),
    this logic still works correctly
 
 ============================================================================
*/

/*
class Node {
    int data;
    Node next;

    Node(int x) {
        data = x;
        next = null;
    }
}
*/

class Solution {

    // Inserts a node at the front of the linked list
    public Node insertAtFront(Node head, int x) {

        // Step 1: Create a new node with given value
        Node newNode = new Node(x);

        // Step 2: Link new node to current head
        newNode.next = head;

        // Step 3: Update head to new node
        head = newNode;

        // Step 4: Return updated head
        return head;
    }
}


